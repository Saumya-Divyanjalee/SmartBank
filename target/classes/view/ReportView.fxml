<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16.0" styleClass="root-bg" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="lk.saumiz.banking.controller.ReportController">

    <Label styleClass="section-title" text="Reports"/>

    <VBox spacing="14.0" styleClass="card">
        <Label styleClass="field-label" text="Generate a PDF account statement for any account"/>
        <HBox spacing="10.0">
            <TextField fx:id="txtAccountNo" promptText="Account No, e.g. ACC0001" HBox.hgrow="ALWAYS"/>
            <Button onAction="#handleGenerateStatement" styleClass="btn-primary" text="Generate Statement (PDF)"/>
        </HBox>
        <Label fx:id="lblMessage" styleClass="msg-info" wrapText="true"/>
    </VBox>

    <padding>
        <Insets bottom="10.0" left="0.0" right="0.0" top="0.0"/>
    </padding>
</VBox>