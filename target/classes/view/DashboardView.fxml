<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="24.0" styleClass="root-bg" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="lk.saumiz.banking.controller.DashboardController">

    <Label styleClass="section-title" text="Dashboard"/>

    <GridPane hgap="18.0" vgap="18.0">
        <columnConstraints>
            <ColumnConstraints percentWidth="33.3"/>
            <ColumnConstraints percentWidth="33.3"/>
            <ColumnConstraints percentWidth="33.3"/>
        </columnConstraints>

        <VBox spacing="6.0" styleClass="stat-card" GridPane.columnIndex="0" GridPane.rowIndex="0">
            <Label styleClass="stat-label" text="TOTAL CUSTOMERS"/>
            <Label fx:id="lblTotalCustomers" styleClass="stat-value" text="0"/>
        </VBox>

        <VBox spacing="6.0" styleClass="stat-card" GridPane.columnIndex="1" GridPane.rowIndex="0">
            <Label styleClass="stat-label" text="TOTAL ACCOUNTS"/>
            <Label fx:id="lblTotalAccounts" styleClass="stat-value" text="0"/>
        </VBox>

        <VBox spacing="6.0" styleClass="stat-card" GridPane.columnIndex="2" GridPane.rowIndex="0">
            <Label styleClass="stat-label" text="TOTAL BANK BALANCE"/>
            <Label fx:id="lblBankBalance" styleClass="stat-value" text="0.00"/>
        </VBox>

        <VBox spacing="6.0" styleClass="stat-card" GridPane.columnIndex="0" GridPane.rowIndex="1">
            <Label styleClass="stat-label" text="TODAY'S DEPOSITS"/>
            <Label fx:id="lblTodayDeposits" styleClass="stat-value" text="0.00"/>
        </VBox>

        <VBox spacing="6.0" styleClass="stat-card" GridPane.columnIndex="1" GridPane.rowIndex="1">
            <Label styleClass="stat-label" text="TODAY'S WITHDRAWALS"/>
            <Label fx:id="lblTodayWithdrawals" styleClass="stat-value" text="0.00"/>
        </VBox>

        <VBox spacing="6.0" styleClass="stat-card" GridPane.columnIndex="2" GridPane.rowIndex="1">
            <Label styleClass="stat-label" text="TODAY'S TRANSFERS"/>
            <Label fx:id="lblTodayTransfers" styleClass="stat-value" text="0.00"/>
        </VBox>
    </GridPane>

    <Label fx:id="lblError" styleClass="msg-error" wrapText="true"/>

    <padding>
        <Insets bottom="10.0" left="0.0" right="0.0" top="0.0"/>
    </padding>
</VBox>