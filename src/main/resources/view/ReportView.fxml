<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="lk.saumiz.banking.controller.ReportController">

    <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Reports"/>
    <Label text="Generate a PDF account statement (JasperReports) for any account."/>

    <HBox spacing="8.0">
        <TextField fx:id="txtAccountNo" promptText="Account No, e.g. ACC0001"/>
        <Button onAction="#handleGenerateStatement" text="Generate Account Statement (PDF)"/>
    </HBox>

    <Label fx:id="lblMessage" wrapText="true"/>

    <padding>
        <Insets bottom="10.0" left="0.0" right="0.0" top="0.0"/>
    </padding>
</VBox>
