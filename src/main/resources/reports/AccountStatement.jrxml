<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="AccountStatement" pageWidth="595" pageHeight="842" columnWidth="535"
              leftMargin="30" rightMargin="30" topMargin="30" bottomMargin="30">

    <!-- Parameters passed in from ReportController -->
    <parameter name="ACCOUNT_NO" class="java.lang.String"/>
    <parameter name="CUSTOMER_NAME" class="java.lang.String"/>
    <parameter name="ACCOUNT_TYPE" class="java.lang.String"/>
    <parameter name="CURRENT_BALANCE" class="java.math.BigDecimal"/>
    <parameter name="GENERATED_DATE" class="java.lang.String"/>

    <!-- Fields come from the transaction list (JRBeanCollectionDataSource) -->
    <field name="transactionId" class="java.lang.String"/>
    <field name="fromAccount" class="java.lang.String"/>
    <field name="toAccount" class="java.lang.String"/>
    <field name="amount" class="java.math.BigDecimal"/>
    <field name="transactionType" class="java.lang.String"/>
    <field name="balanceAfter" class="java.math.BigDecimal"/>
    <field name="transactionDate" class="java.time.LocalDateTime"/>

    <title>
        <band height="90">
            <staticText>
                <reportElement x="0" y="0" width="535" height="24"/>
                <textElement>
                    <font size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[Smart Banking Management System]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="26" width="535" height="18"/>
                <textElement>
                    <font size="12"/>
                </textElement>
                <text><![CDATA[Account Statement]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="48" width="535" height="16"/>
                <textElement><font size="10"/></textElement>
                <textFieldExpression><![CDATA["Account No: " + $P{ACCOUNT_NO} + "   |   Customer: " + $P{CUSTOMER_NAME} + "   |   Type: " + $P{ACCOUNT_TYPE}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="64" width="535" height="16"/>
                <textElement><font size="10"/></textElement>
                <textFieldExpression><![CDATA["Current Balance: Rs. " + $P{CURRENT_BALANCE} + "   |   Generated: " + $P{GENERATED_DATE}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="20">
            <staticText>
                <reportElement x="0" y="0" width="90" height="20" style="header"/>
                <text><![CDATA[Txn ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="90" y="0" width="70" height="20"/>
                <text><![CDATA[From]]></text>
            </staticText>
            <staticText>
                <reportElement x="160" y="0" width="70" height="20"/>
                <text><![CDATA[To]]></text>
            </staticText>
            <staticText>
                <reportElement x="230" y="0" width="70" height="20"/>
                <text><![CDATA[Type]]></text>
            </staticText>
            <staticText>
                <reportElement x="300" y="0" width="80" height="20"/>
                <text><![CDATA[Amount]]></text>
            </staticText>
            <staticText>
                <reportElement x="380" y="0" width="80" height="20"/>
                <text><![CDATA[Balance After]]></text>
            </staticText>
            <staticText>
                <reportElement x="460" y="0" width="75" height="20"/>
                <text><![CDATA[Date]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="18">
            <textField>
                <reportElement x="0" y="0" width="90" height="18"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{transactionId}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="90" y="0" width="70" height="18"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{fromAccount}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="160" y="0" width="70" height="18"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{toAccount}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="230" y="0" width="70" height="18"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{transactionType}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="300" y="0" width="80" height="18"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{amount}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="380" y="0" width="80" height="18"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{balanceAfter}]]></textFieldExpression>
            </textField>
            <textField pattern="yyyy-MM-dd HH:mm">
                <reportElement x="460" y="0" width="75" height="18"/>
                <textElement><font size="7"/></textElement>
                <textFieldExpression><![CDATA[$F{transactionDate}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <summary>
        <band height="30">
            <staticText>
                <reportElement x="0" y="6" width="535" height="16"/>
                <textElement textAlignment="Right"><font size="9" isItalic="true"/></textElement>
                <text><![CDATA[-- End of statement --]]></text>
            </staticText>
        </band>
    </summary>
</jasperReport>
